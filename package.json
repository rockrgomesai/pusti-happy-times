{
  "name": "pusti-ht-mern",
  "version": "1.0.0",
  "description": "Pusti Happy Times MERN Stack Application",
  "scripts": {
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "install:all": "npm run install:backend && npm run install:frontend",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "npm run dev --prefix backend",
    "frontend:dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "concurrently \"npm run backend:start\" \"npm run frontend:start\"",
    "backend:start": "npm start --prefix backend",
    "frontend:start": "npm start --prefix frontend",
    "docker:up": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up -d mongodb redis",
    "docker:down": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml logs -f",
    "start:backend-only": "npm run backend:start",
    "start:frontend-only": "npm run frontend:start",
    "start:all": "npm run docker:up && concurrently \"npm run backend:start\" \"npm run frontend:start\"",
    "dev:all": "npm run docker:up && concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "seed:menu:categories": "npm run seed:menu:categories --prefix backend",
    "seed:products": "npm run seed:products --prefix backend",
    "backup:full": "node db/backup_full.js",
    "dump:db": "node db/dump.js"
  },
  "keywords": [
    "mern",
    "nodejs",
    "nextjs",
    "mongodb",
    "redis"
  ],
  "author": "Pusti Happy Times Team",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "axios": "^1.13.4",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.22.0"
  }
}
